# EDU Capability Velocity — Environment Variables
# Copy this file to .env.local and fill in the values

OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_DRIVE_ACCESS_TOKEN=your_google_drive_access_token_here

# Commercial API protection (recommended in production)
# If set, clients must send this value via x-api-key header or Authorization: Bearer <key>
# COMMERCIAL_API_KEY=replace_with_a_long_random_secret

# Abuse protection controls for /api/chat
# API_RATE_LIMIT_MAX_REQUESTS=30
# API_RATE_LIMIT_WINDOW_MS=60000
# API_MAX_MESSAGES_PER_REQUEST=40
# API_MAX_TEXT_CHARS_PER_REQUEST=40000
# API_MAX_TEXT_CHARS_PER_MESSAGE=8000

# Optional: custom telemetry destination
# CAPABILITY_TELEMETRY_FILE=artifacts/telemetry/capability-events.ndjson
