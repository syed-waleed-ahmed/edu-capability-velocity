# EDU Capability Velocity — Environment Variables
# Copy this file to .env.local and fill in the values

OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_DRIVE_ACCESS_TOKEN=your_google_drive_access_token_here

# Commercial API protection (recommended in production)
# If set, clients must send this value via x-api-key header or Authorization: Bearer <key>
# COMMERCIAL_API_KEY=replace_with_a_long_random_secret
# Auth mode when COMMERCIAL_API_KEY is enabled:
# - strict (default): always require API key
# - safe-browser: allow same-origin browser requests without key, still require key for non-browser requests
# COMMERCIAL_AUTH_MODE=safe-browser

# Abuse protection controls for /api/chat
# API_RATE_LIMIT_MAX_REQUESTS=30
# API_RATE_LIMIT_WINDOW_MS=60000
# Optional distributed limiter backend (recommended on Vercel multi-instance)
# UPSTASH_REDIS_REST_URL=https://<your-upstash-id>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<your-upstash-rest-token>
# API_MAX_MESSAGES_PER_REQUEST=40
# API_MAX_TEXT_CHARS_PER_REQUEST=40000
# API_MAX_TEXT_CHARS_PER_MESSAGE=8000

# Optional: custom telemetry destination
# On Vercel, default is /tmp/capability-events.ndjson when not explicitly set.
# CAPABILITY_TELEMETRY_FILE=/tmp/capability-events.ndjson
# Optional external sink (POST JSON per event)
# CAPABILITY_TELEMETRY_HTTP_ENDPOINT=https://example.com/telemetry-ingest
# CAPABILITY_TELEMETRY_HTTP_TOKEN=replace_with_sink_token

# GitHub Actions secrets for Vercel CD (set in repository settings, not in .env.local):
# VERCEL_TOKEN
# VERCEL_ORG_ID
# VERCEL_PROJECT_ID
